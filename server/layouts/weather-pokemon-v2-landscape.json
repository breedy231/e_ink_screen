{
  "name": "Weather + Pokemon Editorial Layout (Landscape)",
  "description": "Landscape 800x600 version — analog clock, weather left, calendar right, quote above status",
  "dimensions": { "width": 800, "height": 600 },
  "grid": {
    "rows": 12,
    "cols": 12,
    "margin": 20,
    "gap": 4
  },
  "separators": [
    { "row": 3, "color": "#CCCCCC", "width": 1 },
    { "row": 10, "color": "#CCCCCC", "width": 1 }
  ],
  "components": [
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 0, "rowSpan": 3, "colSpan": 3 },
      "config": {
        "padding": 2
      }
    },
    {
      "type": "date",
      "position": { "row": 0, "col": 3, "rowSpan": 1, "colSpan": 7 },
      "config": {
        "fontSize": 20,
        "fontWeight": "normal",
        "textAlign": "left",
        "showDayOfYear": false,
        "dayFormat": "",
        "dateFormat": "EEEE, MMMM do, yyyy",
        "padding": 4
      }
    },
    {
      "type": "weather",
      "position": { "row": 1, "col": 3, "rowSpan": 1, "colSpan": 7 },
      "config": {
        "title": "",
        "fontSize": 18,
        "titleSize": 0,
        "inline": true,
        "showCurrent": true,
        "showForecast": false,
        "showSource": false,
        "showWind": true,
        "showHumidity": true,
        "padding": 4
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 0, "col": 10, "rowSpan": 3, "colSpan": 2 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.85,
        "padding": 2
      }
    },
    {
      "type": "weather",
      "position": { "row": 3, "col": 0, "rowSpan": 2, "colSpan": 5 },
      "config": {
        "title": "",
        "fontSize": 18,
        "titleSize": 0,
        "forecastSize": 1.0,
        "forecastColumns": true,
        "showCurrent": false,
        "showForecast": true,
        "showForecastLabel": false,
        "showSource": false,
        "forecastDays": 3,
        "padding": 0
      }
    },
    {
      "type": "calendar",
      "position": { "row": 3, "col": 6, "rowSpan": 5, "colSpan": 6 },
      "config": {
        "fontSize": 14,
        "maxEventsPerDay": 3,
        "showUpcoming": false,
        "sectionHeaderSize": 1.1,
        "columnGap": 12,
        "padding": 0
      }
    },
    {
      "type": "quote",
      "position": { "row": 8, "col": 0, "rowSpan": 2, "colSpan": 6 },
      "config": {
        "fontSize": 15,
        "fontWeight": "bold",
        "textColor": "#333333",
        "padding": 0
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 11, "col": 0, "rowSpan": 1, "colSpan": 12 },
      "config": {
        "fontSize": 12,
        "textColor": "#999999",
        "padding": 0
      }
    }
  ]
}
