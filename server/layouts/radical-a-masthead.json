{
  "name": "Radical A — Inverted Masthead",
  "description": "Black banner header with white text, airy white body below. E-ink loves solid black.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 0,
    "gap": 0
  },
  "separators": [],
  "components": [
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 0, "rowSpan": 4, "colSpan": 3 },
      "config": {
        "padding": 12,
        "backgroundColor": "#000000",
        "handColor": "#FFFFFF",
        "tickColor": "#FFFFFF",
        "faceColor": "#000000"
      }
    },
    {
      "type": "date",
      "position": { "row": 0, "col": 3, "rowSpan": 2, "colSpan": 5 },
      "config": {
        "fontSize": 20,
        "fontWeight": "bold",
        "textAlign": "left",
        "textColor": "#FFFFFF",
        "backgroundColor": "#000000",
        "showDayOfYear": false,
        "dayFormat": "EEEE",
        "dateFormat": "MMMM do, yyyy",
        "padding": 14
      }
    },
    {
      "type": "weather",
      "position": { "row": 2, "col": 3, "rowSpan": 2, "colSpan": 5 },
      "config": {
        "title": "",
        "fontSize": 17,
        "titleSize": 0,
        "inline": true,
        "showCurrent": true,
        "showForecast": false,
        "showSource": false,
        "showWind": true,
        "showHumidity": false,
        "textColor": "#CCCCCC",
        "backgroundColor": "#000000",
        "padding": 14
      }
    },
    {
      "type": "weather",
      "position": { "row": 5, "col": 0, "rowSpan": 3, "colSpan": 6 },
      "config": {
        "title": "",
        "fontSize": 19,
        "titleSize": 0,
        "forecastSize": 1.0,
        "forecastColumns": true,
        "showCurrent": false,
        "showForecast": true,
        "showForecastLabel": false,
        "showSource": false,
        "forecastDays": 3,
        "padding": 28
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 5, "col": 6, "rowSpan": 3, "colSpan": 2 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.85,
        "padding": 8
      }
    },
    {
      "type": "calendar",
      "position": { "row": 9, "col": 0, "rowSpan": 7, "colSpan": 8 },
      "config": {
        "fontSize": 15,
        "maxEventsPerDay": 4,
        "showUpcoming": false,
        "sectionHeaderSize": 1.15,
        "columnGap": 24,
        "padding": 28
      }
    },
    {
      "type": "quote",
      "position": { "row": 16, "col": 0, "rowSpan": 3, "colSpan": 8 },
      "config": {
        "fontSize": 13,
        "fontWeight": "normal",
        "textColor": "#777777",
        "padding": 28
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 19, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 11,
        "textColor": "#AAAAAA",
        "padding": 28
      }
    }
  ]
}
