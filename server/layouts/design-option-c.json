{
  "name": "Design Option C — Bold Anchor",
  "description": "Oversized clock dominates top half, compact info below. Newspaper front-page feel.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 28,
    "gap": 2
  },
  "separators": [],
  "components": [
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 1, "rowSpan": 6, "colSpan": 6 },
      "config": {
        "padding": 8
      }
    },
    {
      "type": "date",
      "position": { "row": 6, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 22,
        "fontWeight": "bold",
        "textAlign": "center",
        "showDayOfYear": false,
        "dayFormat": "",
        "dateFormat": "EEEE, MMMM do, yyyy",
        "padding": 0
      }
    },
    {
      "type": "weather",
      "position": { "row": 7, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "title": "",
        "fontSize": 16,
        "titleSize": 0,
        "inline": true,
        "showCurrent": true,
        "showForecast": false,
        "showSource": false,
        "showWind": true,
        "showHumidity": true,
        "textColor": "#444444",
        "textAlign": "center",
        "padding": 0
      }
    },
    {
      "type": "weather",
      "position": { "row": 9, "col": 0, "rowSpan": 2, "colSpan": 4 },
      "config": {
        "title": "",
        "fontSize": 16,
        "titleSize": 0,
        "forecastSize": 1.0,
        "forecastColumns": false,
        "showCurrent": false,
        "showForecast": true,
        "showForecastLabel": false,
        "showSource": false,
        "forecastDays": 3,
        "padding": 0
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 9, "col": 5, "rowSpan": 3, "colSpan": 3 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.85,
        "padding": 2
      }
    },
    {
      "type": "calendar",
      "position": { "row": 12, "col": 0, "rowSpan": 5, "colSpan": 8 },
      "config": {
        "fontSize": 14,
        "maxEventsPerDay": 3,
        "showUpcoming": false,
        "sectionHeaderSize": 1.15,
        "columnGap": 20,
        "padding": 0
      }
    },
    {
      "type": "quote",
      "position": { "row": 17, "col": 0, "rowSpan": 2, "colSpan": 8 },
      "config": {
        "fontSize": 13,
        "fontWeight": "normal",
        "textColor": "#666666",
        "padding": 0
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 19, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 11,
        "textColor": "#AAAAAA",
        "padding": 0
      }
    }
  ]
}
