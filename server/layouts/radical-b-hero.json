{
  "name": "Radical B — Hero Weather",
  "description": "Temperature dominates the screen. Weather-first, glanceable from across the room.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 28,
    "gap": 2
  },
  "separators": [],
  "components": [
    {
      "type": "hero-weather",
      "position": { "row": 0, "col": 0, "rowSpan": 5, "colSpan": 5 },
      "config": {
        "fontSize": 120,
        "fontWeight": "bold",
        "textAlign": "left",
        "conditionSize": 0.2,
        "padding": 0
      }
    },
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 5, "rowSpan": 3, "colSpan": 3 },
      "config": {
        "padding": 4
      }
    },
    {
      "type": "date",
      "position": { "row": 3, "col": 5, "rowSpan": 2, "colSpan": 3 },
      "config": {
        "fontSize": 14,
        "fontWeight": "normal",
        "textAlign": "center",
        "textColor": "#444444",
        "showDayOfYear": false,
        "dayFormat": "EEEE",
        "dateFormat": "MMM do",
        "padding": 4
      }
    },
    {
      "type": "weather",
      "position": { "row": 6, "col": 0, "rowSpan": 3, "colSpan": 6 },
      "config": {
        "title": "",
        "fontSize": 18,
        "titleSize": 0,
        "forecastSize": 1.0,
        "forecastColumns": true,
        "showCurrent": false,
        "showForecast": true,
        "showForecastLabel": false,
        "showSource": false,
        "forecastDays": 3,
        "padding": 0
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 6, "col": 6, "rowSpan": 3, "colSpan": 2 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.85,
        "padding": 2
      }
    },
    {
      "type": "calendar",
      "position": { "row": 10, "col": 0, "rowSpan": 6, "colSpan": 8 },
      "config": {
        "fontSize": 15,
        "maxEventsPerDay": 4,
        "showUpcoming": false,
        "sectionHeaderSize": 1.15,
        "columnGap": 20,
        "padding": 0
      }
    },
    {
      "type": "quote",
      "position": { "row": 17, "col": 0, "rowSpan": 2, "colSpan": 8 },
      "config": {
        "fontSize": 13,
        "fontWeight": "normal",
        "textColor": "#666666",
        "padding": 0
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 19, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 11,
        "textColor": "#AAAAAA",
        "padding": 0
      }
    }
  ]
}
