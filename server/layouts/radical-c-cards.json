{
  "name": "Radical C — Card Layout",
  "description": "Each section in its own rounded card. Modern, structured, app-like feel.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 16,
    "gap": 8
  },
  "separators": [],
  "components": [
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 0, "rowSpan": 4, "colSpan": 3 },
      "config": {
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 10
      }
    },
    {
      "type": "date",
      "position": { "row": 0, "col": 3, "rowSpan": 2, "colSpan": 3 },
      "config": {
        "fontSize": 16,
        "fontWeight": "normal",
        "textAlign": "left",
        "showDayOfYear": false,
        "dayFormat": "EEEE",
        "dateFormat": "MMMM do, yyyy",
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 12
      }
    },
    {
      "type": "weather",
      "position": { "row": 2, "col": 3, "rowSpan": 2, "colSpan": 3 },
      "config": {
        "title": "",
        "fontSize": 15,
        "titleSize": 0,
        "inline": false,
        "showCurrent": true,
        "showForecast": false,
        "showSource": false,
        "showWind": true,
        "showHumidity": false,
        "heroSize": 1.3,
        "compactDetails": true,
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 12
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 0, "col": 6, "rowSpan": 4, "colSpan": 2 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.8,
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 8
      }
    },
    {
      "type": "weather",
      "position": { "row": 4, "col": 0, "rowSpan": 3, "colSpan": 8 },
      "config": {
        "title": "",
        "fontSize": 18,
        "titleSize": 0,
        "forecastSize": 1.0,
        "forecastColumns": true,
        "showCurrent": false,
        "showForecast": true,
        "showForecastLabel": false,
        "showSource": false,
        "forecastDays": 3,
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 14
      }
    },
    {
      "type": "calendar",
      "position": { "row": 7, "col": 0, "rowSpan": 7, "colSpan": 8 },
      "config": {
        "fontSize": 14,
        "maxEventsPerDay": 4,
        "showUpcoming": false,
        "sectionHeaderSize": 1.15,
        "columnGap": 16,
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 14
      }
    },
    {
      "type": "quote",
      "position": { "row": 14, "col": 0, "rowSpan": 3, "colSpan": 8 },
      "config": {
        "fontSize": 13,
        "fontWeight": "normal",
        "textColor": "#555555",
        "backgroundColor": "#F0F0F0",
        "borderRadius": 12,
        "padding": 14
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 19, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 11,
        "textColor": "#AAAAAA",
        "padding": 8
      }
    }
  ]
}
