{
  "name": "Wild B — Art Poster",
  "description": "Massive weather illustration as hero. Temperature huge. Minimal text. Gallery wall piece.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 24,
    "gap": 4
  },
  "separators": [],
  "components": [
    {
      "type": "weather-illustration",
      "position": { "row": 0, "col": 0, "rowSpan": 8, "colSpan": 8 },
      "config": {
        "strokeColor": "#000000",
        "lineWidth": 3,
        "padding": 20
      }
    },
    {
      "type": "hero-weather",
      "position": { "row": 8, "col": 0, "rowSpan": 3, "colSpan": 5 },
      "config": {
        "fontSize": 80,
        "fontWeight": "bold",
        "textAlign": "left",
        "conditionSize": 0.25,
        "padding": 0
      }
    },
    {
      "type": "analog-clock",
      "position": { "row": 8, "col": 5, "rowSpan": 3, "colSpan": 3 },
      "config": {
        "padding": 6
      }
    },
    {
      "type": "date",
      "position": { "row": 11, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 18,
        "fontWeight": "bold",
        "textAlign": "left",
        "showDayOfYear": false,
        "dayFormat": "",
        "dateFormat": "EEEE, MMMM do, yyyy",
        "padding": 0
      }
    },
    {
      "type": "calendar",
      "position": { "row": 12, "col": 0, "rowSpan": 5, "colSpan": 5 },
      "config": {
        "fontSize": 13,
        "maxEventsPerDay": 3,
        "showUpcoming": false,
        "sectionHeaderSize": 1.15,
        "columnGap": 14,
        "padding": 0
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 12, "col": 5, "rowSpan": 4, "colSpan": 3 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.9,
        "padding": 4
      }
    },
    {
      "type": "quote",
      "position": { "row": 17, "col": 0, "rowSpan": 2, "colSpan": 8 },
      "config": {
        "fontSize": 13,
        "fontWeight": "normal",
        "textColor": "#666666",
        "padding": 0
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 19, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 11,
        "textColor": "#AAAAAA",
        "padding": 0
      }
    }
  ]
}
