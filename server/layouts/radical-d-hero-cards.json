{
  "name": "Radical D — Hero Cards",
  "description": "Hero temperature for glanceability, card structure for organization. Best of B + C.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 16,
    "gap": 8
  },
  "separators": [],
  "components": [
    {
      "type": "hero-weather",
