      "config": {
        "fontSize": 110,
        "fontWeight": "bold",
        "textAlign": "left",
        "conditionSize": 0.22,
        "borderColor": "#CCCCCC",
        "borderWidth": 1,
        "borderRadius": 12,
        "padding": 16
      }
    },
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 5, "rowSpan": 3, "colSpan": 3 },
