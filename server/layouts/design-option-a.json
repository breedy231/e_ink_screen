{
  "name": "Design Option A — Airy Editorial",
  "description": "Maximum whitespace, no separator lines, strong typographic hierarchy. Sections breathe.",
  "grid": {
    "rows": 20,
    "cols": 8,
    "margin": 32,
    "gap": 2
  },
  "separators": [],
  "components": [
    {
      "type": "analog-clock",
      "position": { "row": 0, "col": 0, "rowSpan": 4, "colSpan": 4 },
      "config": {
        "padding": 4
      }
    },
    {
      "type": "pokemon-sprite",
      "position": { "row": 0, "col": 5, "rowSpan": 4, "colSpan": 3 },
      "config": {
        "showNumber": false,
        "showName": false,
        "spriteSize": 0.9,
        "padding": 4
      }
    },
    {
      "type": "date",
      "position": { "row": 4, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 20,
        "fontWeight": "normal",
        "textAlign": "left",
        "showDayOfYear": false,
        "dayFormat": "",
        "dateFormat": "EEEE, MMMM do, yyyy",
        "padding": 0
      }
    },
    {
      "type": "weather",
      "position": { "row": 5, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "title": "",
        "fontSize": 17,
        "titleSize": 0,
        "inline": true,
        "showCurrent": true,
        "showForecast": false,
        "showSource": false,
        "showWind": false,
        "showHumidity": false,
        "textColor": "#444444",
        "padding": 0
      }
    },
    {
      "type": "weather",
      "position": { "row": 7, "col": 0, "rowSpan": 3, "colSpan": 8 },
      "config": {
        "title": "",
        "fontSize": 18,
        "titleSize": 0,
        "forecastSize": 1.0,
        "forecastColumns": true,
        "showCurrent": false,
        "showForecast": true,
        "showForecastLabel": false,
        "showSource": false,
        "forecastDays": 3,
        "padding": 0
      }
    },
    {
      "type": "calendar",
      "position": { "row": 11, "col": 0, "rowSpan": 5, "colSpan": 8 },
      "config": {
        "fontSize": 15,
        "maxEventsPerDay": 4,
        "showUpcoming": false,
        "sectionHeaderSize": 1.1,
        "columnGap": 24,
        "padding": 0
      }
    },
    {
      "type": "quote",
      "position": { "row": 17, "col": 0, "rowSpan": 2, "colSpan": 8 },
      "config": {
        "fontSize": 14,
        "fontWeight": "normal",
        "textColor": "#666666",
        "padding": 0
      }
    },
    {
      "type": "status-bar",
      "position": { "row": 19, "col": 0, "rowSpan": 1, "colSpan": 8 },
      "config": {
        "fontSize": 11,
        "textColor": "#AAAAAA",
        "padding": 0
      }
    }
  ]
}
